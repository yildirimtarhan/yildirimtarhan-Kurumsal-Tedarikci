    <style>
        body { font-family: 'Arial', sans-serif; line-height: 1.6; color: #333; padding: 40px; }
        .header { text-align: right; margin-bottom: 40px; }
        .subject { font-weight: bold; margin-bottom: 30px; text-decoration: underline; }
