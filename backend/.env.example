# Kurumsal Tedarikçi - Ortam Değişkenleri Örneği
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun: cp .env.example .env

# Zorunlu
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/kurumsal-tedarikci
JWT_SECRET=buraya-guclu-rastgele-bir-secret-yazin

# Admin panel girişi (admin login)
ADMIN_USER=admin
ADMIN_PASS=guclu-sifre

# E-posta (Brevo / SMTP)
BREVO_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@tedarikci.org.tr
EMAIL_FROM=noreply@tedarikci.org.tr
EMAIL_FROM_NAME=Kurumsal Tedarikçi

# ERP entegrasyonu
ERP_BASE_URL=
ERP_API_KEY=

# Taxten e-fatura
TAXTEN_ENV=test
TAXTEN_USERNAME=
TAXTEN_PASSWORD=
TAXTEN_VKN=
TAXTEN_GB_ETIKET=
TAXTEN_TEST_CLIENT_ID=
TAXTEN_TEST_API_KEY=

# Firma bilgileri (e-fatura için)
FIRMA_VKN=
FIRMA_UNVAN=
FIRMA_IL=
FIRMA_ILCE=
FIRMA_ADRES=
FIRMA_BINA_NO=
FIRMA_POSTA_KODU=
FIRMA_TELEFON=
FIRMA_EMAIL=
FIRMA_WEBSITE=
FIRMA_VERGI_DAIRESI=

# SMS (NetGSM veya Twilio)
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_HEADER=KURUMSAL
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_NUMBER=

# Kargo
YURTICI_USER=
YURTICI_PASS=
YURTICI_API_URL=
ARAS_API_KEY=
ARAS_API_URL=
MNG_CUSTOMER_NO=
MNG_PASSWORD=
MNG_API_URL=

# Frontend URL (e-posta linkleri için)
FRONTEND_URL=https://tedarikci.org.tr
