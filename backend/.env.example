# Kurumsal Tedarikçi - Ortam Değişkenleri Örneği
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun: cp .env.example .env

# Zorunlu
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/kurumsal-tedarikci
JWT_SECRET=buraya-guclu-rastgele-bir-secret-yazin

# Admin panel girişi (admin login)
ADMIN_USER=admin
ADMIN_PASS=guclu-sifre

# E-posta — kayıt, sipariş onayı, kargo, şifre sıfırlama, bayilik vb.
#
# Yöntem A (önerilen): Brevo Transactional API anahtarı
#   Brevo → SMTP & API → API keys → v3 key. Gönderen adresi Brevo’da doğrulanmış olmalı.
BREVO_API_KEY=
#
# Yöntem B: Sadece SMTP (Brevo SMTP veya başka sağlayıcı). BREVO_API_KEY boşsa otomatik kullanılır.
# Üçü birlikte zorunlu: SMTP_HOST + SMTP_USER + SMTP_PASS
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@tedarikci.org.tr
SMTP_FROM_NAME=Kurumsal Tedarikçi
EMAIL_FROM=noreply@tedarikci.org.tr
EMAIL_FROM_NAME=Kurumsal Tedarikçi

# Yeni siparişte admin e-posta bildirimi (virgülle birden fazla adres)
ADMIN_ORDER_NOTIFY_EMAIL=
# Render’da bazen NOTIFY_EMAIL kullanılmış; boşsa kod bunu da okur
# NOTIFY_EMAIL=

# AI pazarlama (admin /marketing — teklif metni, sosyal içerik)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ——— Giden sesli arama (TTS) — Türkiye cep (+90 5xx) ———
# netgsm: NetGSM "Sesli Mesaj" + API (NETGSM_USERCODE/PASSWORD). https://api.netgsm.com.tr/voicesms/send
# twilio: Twilio Voice + TwiML
# webhook: Kendi middleware URL'nize JSON POST
VOICE_PROVIDER=none
#
# NetGSM ses (VOICE_PROVIDER=netgsm) — abonelikte Sesli Mesaj + API yetkisi gerekir
# NETGSM_USERCODE ve NETGSM_PASSWORD SMS ile aynı olabilir
NETGSM_VOICE_RINGTIME=25
# Gönderim penceresi (saat), 1–21 arası önerilir
NETGSM_VOICE_WINDOW_HOURS=2
# İsteğe bağlı: NetGSM'in arama sonucunu POST etmesi için token + bu URL otomatik XML'e eklenir:
# .../api/voice/netgsm-report?token=GIZLI
NETGSM_VOICE_WEBHOOK_TOKEN=
#
# Twilio ses (VOICE_PROVIDER=twilio)
TWILIO_VOICE_FROM=
# TWILIO_SID ve TWILIO_TOKEN SMS ile aynı olabilir
#
# Harici köprü (VOICE_PROVIDER=webhook)
VOICE_WEBHOOK_URL=
VOICE_WEBHOOK_SECRET=

# ERP entegrasyonu
ERP_BASE_URL=
ERP_API_KEY=

# Taxten e-fatura
TAXTEN_ENV=test
TAXTEN_USERNAME=
TAXTEN_PASSWORD=
TAXTEN_VKN=
TAXTEN_GB_ETIKET=
TAXTEN_TEST_CLIENT_ID=
TAXTEN_TEST_API_KEY=

# Firma bilgileri (e-fatura için)
FIRMA_VKN=
FIRMA_UNVAN=
FIRMA_IL=
FIRMA_ILCE=
FIRMA_ADRES=
FIRMA_BINA_NO=
FIRMA_POSTA_KODU=
FIRMA_TELEFON=
FIRMA_EMAIL=
FIRMA_WEBSITE=
FIRMA_VERGI_DAIRESI=

# SMS (NetGSM veya Twilio)
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_HEADER=KURUMSAL
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_NUMBER=

# Kargo
YURTICI_USER=
YURTICI_PASS=
YURTICI_API_URL=
ARAS_API_KEY=
ARAS_API_URL=
MNG_CUSTOMER_NO=
MNG_PASSWORD=
MNG_API_URL=
# HepsiJET (Integration / Test)
# Maildeki test kullanıcı bilgilerini buraya girin (koda gömmeyin).
HEPSIJET_API_URL=https://integration-apitest.hepsijet.com/
HEPSIJET_USER=
HEPSIJET_PASSWORD=
# Company (abbreviationCode) / merchantId
HEPSIJET_CUSTOMER_CODE=KURUMSAL
# Bazı hesaplarda token için ayrıca merchantId istenir (dokümandaki karşılığı neyse onu yazın).
# Boşsa HEPSIJET_CUSTOMER_CODE kullanılır.
HEPSIJET_MERCHANT_ID=
# SenderAddress(CompanyAddressID)
HEPSIJET_COMPANY_ADDRESS_ID=kuru-kurumsal-202
# CurrentXdock(abbreviationCode)
HEPSIJET_XDOCK_CODE=KURUMSALBANDIRMA
# SenderAddress (opsiyonel; dokümanda istenirse gönderilir)
HEPSIJET_SENDER_COUNTRY=Türkiye
HEPSIJET_SENDER_CITY=BALIKESİR
HEPSIJET_SENDER_TOWN=BANDIRMA
HEPSIJET_SENDER_DISTRICT=HACI YUSUF
HEPSIJET_SENDER_ADDRESS_LINE1=HACI YUSUF MH. ESER SK. NO:4-10 BANDIRMA-BALIKESİR

# Frontend URL (e-posta linkleri ve OAuth dönüşü için — tam site kökü, sonda / olmasın)
FRONTEND_URL=https://tedarikci.org.tr

# İsteğe bağlı: CORS (virgülle birden fazla tam origin, örn. https://proje-xxx.vercel.app)
# CORS_ORIGINS=

# OAuth oturumu (Google/Facebook girişi; üretimde SESSION_SECRET kullanın)
SESSION_SECRET=

# Sosyal girişleri geçici kapat (1/true/yes/on)
OAUTH_DISABLED=0

# Google ile giriş — https://console.cloud.google.com/apis/credentials
# Yetkili yönlendirme URI: https://SIZIN-BACKEND/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Opsiyonel; boşsa BACKEND_PUBLIC_URL / RENDER_EXTERNAL_URL / localhost:PORT ile üretilir
GOOGLE_CALLBACK_URL=

# Facebook ile giriş — https://developers.facebook.com/apps
# Geçerli OAuth yönlendirme URI: https://SIZIN-BACKEND/api/auth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=

# OAuth callback tam URL için; örn. https://backend-api-xxx.onrender.com
# Render: genelde ayarlamanız gerekmez — RENDER_EXTERNAL_URL otomatik kullanılır.
# Yine de özel alan adı veya proxy kullanıyorsanız burayı doldurun.
BACKEND_PUBLIC_URL=

# Instagram ile giriş (Meta — Instagram Business Login)
# Gerekli: İşletme veya İçerik Üretici Instagram hesabı; Meta uygulamasında Instagram ürünü + Business login
# OAuth yönlendirme URI: https://SIZIN-BACKEND/api/auth/instagram/callback
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Alternatif isimler (boşsa yukarıdakiler kullanılır)
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=
# Varsayılan: instagram_business_basic
# INSTAGRAM_SCOPE=instagram_business_basic
# Graph sürümü (gerekirse)
# INSTAGRAM_GRAPH_VERSION=v21.0

# Opsiyonel: boş bırakılırsa FRONTEND_URL üzerinden siparisler.html'e döner

